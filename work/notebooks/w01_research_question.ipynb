        "from pathlib import Path\n",
        "import pandas as pd\n",
        "\n",
        "local_path = Path(\"data/raw/content_refresh_anonymized.csv\")\n",
        "remote_url = (\n",
        "    \"https://raw.githubusercontent.com/\"\n",
        "    \"bsse23-060/Saram_Flyrank1/main/\"\n",
        "    \"data/raw/content_refresh_anonymized.csv\"\n",
        ")\n",
        "\n",
        "data_source = local_path if local_path.exists() else remote_url\n",
        "df = pd.read_csv(data_source)\n",
        "\n",
        "is_down = df[\"trend_direction\"].astype(str).str.lower().eq(\"down\")\n",
        "visible = df[\"impressions_90d\"].ge(100)\n",
        "visible_and_down = visible & is_down\n",
        "\n",
        "print(f\"Content rows: {len(df):,}\")\n",
        "print(f\"Pseudonymous clients: {df['client_id'].nunique():,}\")\n",
        "print(f\"Rows labeled down: {is_down.sum():,} ({is_down.mean():.2%})\")\n",
        "print(\n",
        "    f\"Visible rows labeled down: {visible_and_down.sum():,} \"\n",
        "    f\"of {visible.sum():,} \"\n",
        "    f\"({visible_and_down.sum() / visible.sum():.2%})\"\n",
        ")"
      ],
